<mujoco model="conveyor_belt">
  <asset>
    <mesh name="mesh_belt" file="belt.stl" scale="0.1 0.1 0.1"/>
    <mesh name="mesh_roller1" file="roller1.stl" scale="0.1 0.1 0.1"/>
    <mesh name="mesh_roller2" file="roller2.stl" scale="0.1 0.1 0.1"/>
    <mesh name="mesh_fixtures" file="fixtures.stl" scale="0.1 0.1 0.1"/>

    <texture name="tex_pvc_green" type="2d" file="pvc_green.png" />
    <texture name="tex_metal1" type="2d" file="metal1.png" />
    <material name="mat_belt_pvc" texture="tex_pvc_green" reflectance="0.1" rgba="1 1 1 1"/>
    <material name="mat_roller_metal" texture="tex_metal1" reflectance="0.9" rgba="1 1 1 1"/>
  </asset>
    <!-- <worldbody>
        <body>
            <geom type="plane" size="1 1 0.01" contype="0" conaffinity="0"/>
        </body>
    </worldbody> -->

<worldbody>
    <body>
      <body name="object">
        <body name="conveyor_belt" pos="0 0 0">
          <geom type="mesh" mesh="mesh_fixtures" material="mat_roller_metal" group="0" friction="0.95 0.3 0.1" contype="0" conaffinity="0" pos="0 0 0"/>
          <site name="belt_region" type="box" size="0.25 1 0.01" pos="0 0 0" quat="1 0 0 0" rgba="0 1 0 1" group="0"/>

          <body name="roller1" euler="0 0 0" pos="0 0 0">
            <geom type="mesh" mesh="mesh_roller1" material="mat_roller_metal" group="0" friction="0.95 0.3 0.1" contype="0" conaffinity="0"/>
            <!-- <geom type="box" size="0.06 0.06 0.001" pos="0 0 0" group="0" material="mat_roller_metal"/> -->
            <joint name="roller1_joint" type="hinge" damping="0.01" axis="1 0 0" limited="true" range="-360 360"/>
          </body>

          <body name="roller2" euler="0 0 0" pos="0 0 0">
            <geom type="mesh" mesh="mesh_roller2" material="mat_roller_metal" group="1" friction="0.95 0.3 0.1" contype="0" conaffinity="0"/>
            <!-- <geom type="box" size="0.06 0.06 0.001" pos="0 0 0" group="0" material="mat_roller_metal"/> -->
            <joint name="roller2_joint" type="hinge" damping="0.01" axis="1 0 0" limited="true" range="-360 360"/>
          </body>

          <body name="belt" pos="0 0 0">
            <inertial pos="0 0 0" mass="3"/>
            <geom type="mesh" mesh="mesh_belt" material="mat_belt_pvc" group="1" friction="0.001 0.005 0.001" contype="1" conaffinity="1"/>
            <site name="belt_touch_sensor_site" type="box" size="1 0.25 0.01"/>

            <body name="right_light_sensor" pos="0 0.25 0.03">
              <geom type="cylinder" size="0.005 0.25" euler="90 90 0" rgba="1 1 0 1" contype="0" conaffinity="0" group="0"/>
            </body>

            <body name="left_light_sensor" pos="0 -0.25 0.03">
              <geom type="cylinder" size="0.005 0.25" euler="90 90 0" rgba="1 1 0 1" contype="0" conaffinity="0" group="0"/>
            </body>
          </body>
        </body>
      </body>
      
      <!-- REQUIRED SITES for MujocoXMLObject -->
      <site rgba="0 0 0 0" size="0.005" pos="0 0 0.16" name="bottom_site"/>
      <site rgba="0 0 0 0" size="0.005" pos="0 0 0.18" name="top_site"/>
      <site rgba="0 0 0 0" size="0.005" pos="1.1 0 0.17" name="horizontal_radius_site"/>
    </body>
  </worldbody>

  <equality>
    <joint joint1="roller1_joint" joint2="roller2_joint" />
  </equality>

  <actuator>
    <velocity name="roller_vel" joint="roller1_joint" ctrlrange="-20 20" />
  </actuator>

  <sensor>
    <touch site="belt_touch_sensor_site"/>
  </sensor>
</mujoco>