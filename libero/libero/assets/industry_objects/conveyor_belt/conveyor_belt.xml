<mujoco model="conveyor_belt">
    <size njmax="500" nconmax="100" />
    <asset>
      <mesh name="mesh_belt" file="belt.obj" scale="0.2 0.2 0.2" />
      <mesh name="mesh_fixtures" file="fixtures.obj" scale="0.2 0.2 0.2"/>

      <texture name="tex_pvc_green" type="2d" file="pvc_green.png" />
      <texture name="tex_metal" type="2d" file="metal.png" />
      <material name="mat_belt_pvc" texture="tex_pvc_green" reflectance="0.1" rgba="1 1 1 1"/>
      <material name="mat_roller_metal" texture="tex_metal" reflectance="0.9" rgba="1 1 1 1"/>
    </asset>

<worldbody>
    <body>
      <body name="object">
        <!-- Blender-style export: belt length along local +Y; rotate -90° about Z so length
             aligns with +X in the parent (main) frame. Use quat (w x y z), not euler, to avoid
             eulerseq surprises. If the mesh faces the wrong end, flip sign of the Z component. -->
        <body name="conveyor_belt" pos="0 0 0.0196" quat="0.7071067811865476 0 0 -0.7071067811865476">
          <joint name="belt_hinge" type="hinge" axis="0 1 0" pos="0 0 0.1" />
          <inertial pos="0 0 0" mass="1000" diaginertia="1000 1000 1000" />
          <geom solimp="0.998 0.998 0.001" solref="0.001 1" density="100" type="mesh" mesh="mesh_belt" material="mat_belt_pvc" group="1" friction="0.001 0.005 0.001" contype="1" conaffinity="1" pos="0 0 0"/>
          <geom solimp="0.998 0.998 0.001" solref="0.001 1" density="100" type="mesh" mesh="mesh_fixtures" material="mat_roller_metal" group="1" friction="0.6 0.005 0.001" contype="0" conaffinity="0" pos="0 0 0"/>
          <geom name="contact_region" type="box" size="0.0768 0.4804 0.001" pos="0.02 0 0.0195" quat="1 0 0 0" rgba="1 0 0 1" group='0'/>         
          <site name="contact_region" type="box" size="0.0768 0.4804 0.001" pos="0.02 0 0.0195" quat="1 0 0 0" rgba="1 0 0 0" group='0'/>
          <site name="offset_region_1" type="box" size="0.04 0.06 0.001" pos="0.02 -0.4 0.0196" quat="1 0 0 0" rgba="0 1 0 0.3" group='0'/>
          <site name="offset_region_2" type="box" size="0.04 0.06 0.001" pos="0.02 -0.3 0.0196" quat="1 0 0 0" rgba="0 0 1 0.3" group='0'/>
          <site name="offset_region_3" type="box" size="0.04 0.06 0.001" pos="0.02 -0.2 0.0196" quat="1 0 0 0" rgba="1 1 0 0.3" group='0'/>
          <site name="offset_region_4" type="box" size="0.04 0.06 0.001" pos="0.02 -0.1 0.0196" quat="1 0 0 0" rgba="1 0 1 0.3" group='0'/>
          <site name="offset_region_5" type="box" size="0.04 0.06 0.001" pos="0.02 0.0 0.0196" quat="1 0 0 0" rgba="0 1 1 0.3" group='0'/>
          <site name="stack_region_1" type="box" size="0.04 0.06 0.001" pos="0.02 -0.4 0.0196" quat="1 0 0 0" rgba="0 1 0 0.3" group='0'/>
          <site name="stack_region_2" type="box" size="0.04 0.06 0.001" pos="0.02 -0.4 0.0196" quat="1 0 0 0" rgba="0 0 1 0.3" group='0'/>
          <site name="stack_region_3" type="box" size="0.04 0.06 0.001" pos="0.02 -0.4 0.0196" quat="1 0 0 0" rgba="1 1 0 0.3" group='0'/>
          <site name="stack_region_4" type="box" size="0.04 0.06 0.001" pos="0.02 -0.4 0.0196" quat="1 0 0 0" rgba="1 0 1 0.3" group='0'/>
          <site name="stack_region_5" type="box" size="0.04 0.06 0.001" pos="0.02 -0.4 0.0196" quat="1 0 0 0" rgba="0 1 1 0.3" group='0'/>
        </body>
      </body>
      
      <!-- REQUIRED SITES for MujocoXMLObject -->
      <site rgba="0 0 0 0" size="0.05" pos="0 0 -0.0392" name="bottom_site"/>
      <site rgba="0 0 0 0" size="0.05" pos="0 0 0.0392" name="top_site"/>
      <site rgba="0 0 0 0" size="0.05" pos="0 0 0.0196" name="horizontal_radius_site"/>
    </body>
  </worldbody>

</mujoco>
