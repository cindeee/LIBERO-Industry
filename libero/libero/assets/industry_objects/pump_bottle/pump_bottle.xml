<mujoco model="pump_bottle">
    <size njmax="500" nconmax="100" />
    <asset>
      <mesh name="mesh_base" file="base.obj" scale="1 1 1" />
      <mesh name="mesh_cap" file="cap.obj" scale="1 1 1"/>
      <mesh name="mesh_pump" file="pump.obj" scale="1 1 1"/>
    </asset>

  <worldbody>
    <body>
      <body name="object" pos="0 0 0" quat="1 0 0 0">
      <inertial pos="0 0 0" mass="0.5" diaginertia="1e-3 1e-3 1e-3" />       
         
        <geom type="mesh" mesh="mesh_base" rgba="1 1 1 0.2" friction="0.6 0.005 0.001" quat="0.7071068 -0.7071068 0 0" group="1" contype="1" conaffinity="1" pos="0 0 0"/>
        <geom type="mesh" mesh="mesh_cap" rgba="1 1 1 0.2" friction="0.6 0.005 0.001" quat="0.7071068 -0.7071068 0 0" group="1" contype="1" conaffinity="1" pos="0 0 0"/>
        <geom type="mesh" mesh="mesh_pump" rgba="1 1 1 1" friction="0.6 0.005 0.001" quat="0.7071068 -0.7071068 0 0" group="1" contype="1" conaffinity="1" pos="0 0 0"/>
        
        <site name="bottle_site" type="cylinder" size="0.01635 0.061" pos="0 0 0" euler="90 0 0" rgba="1 0 0 0"/>
        
        <site name="contact_site" type="cylinder" size="0.01635 0.061" pos="0 0 0" euler="90 0 0" rgba="0 0 1 0" group="0"/>
      </body>
      <site rgba="0 0 1 1" size="0.01" pos="0 0 -0.061" quat="1 0 0 0" name="bottom_site"/>  
      <site rgba="0 1 0 1" size="0.01" pos="0 0 0.061" quat="1 0 0 0" name="top_site"/>   
      <site rgba="1 0 0 1" size="0.01" pos="0.01635 0 0" quat="1 0 0 0" name="horizontal_radius_site"/>
    </body>
  </worldbody>
</mujoco>