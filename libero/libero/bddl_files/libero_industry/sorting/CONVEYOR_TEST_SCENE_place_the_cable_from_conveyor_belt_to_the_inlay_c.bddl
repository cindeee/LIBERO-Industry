(define (problem LIBERO_Industry_Workbench_Manipulation)
  (:domain robosuite)
  (:language place the cable from conveyor belt to the inlay c)
    (:regions
      (conveyor_belt_init_region
          (:target industry_workbench)
          (:ranges (
              (-0.05 -0.05 0.05 0.05)
            )
          )
          (:yaw_rotation (
              (1.5707963267948966 1.5707963267948966)
            )
          )
      )
      (carrier_region
          (:target industry_workbench)
          (:ranges (
              (-0.25 -0.05 -0.15000000000000002 0.05)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (contact_region
          (:target conveyor_belt_1)
      )
      (offset_region_1
          (:target conveyor_belt_1)
      )
      (offset_region_2
          (:target conveyor_belt_1)
      )
      (offset_region_3
          (:target conveyor_belt_1)
      )
      (offset_region_4
          (:target conveyor_belt_1)
      )
      (offset_region_5
          (:target conveyor_belt_1)
      )
      (stack_region_1
          (:target conveyor_belt_1)
      )
      (stack_region_2
          (:target conveyor_belt_1)
      )
      (stack_region_3
          (:target conveyor_belt_1)
      )
      (stack_region_4
          (:target conveyor_belt_1)
      )
      (stack_region_5
          (:target conveyor_belt_1)
      )
    )

  (:fixtures
    industry_workbench - industry_workbench
    conveyor_belt_1 - conveyor_belt
  )

  (:objects
    cable_1 cable_2 - cable
  )

  (:obj_of_interest
  )

  (:init
    (On conveyor_belt_1 industry_workbench_conveyor_belt_init_region)
    (On cable_1 conveyor_belt_1_offset_region_5)
  )

  (:goal
    (And)
  )

)
