(define (problem LIBERO_Industry_Workbench_Manipulation)
  (:domain robosuite)
  (:language place the pump bottle into the moving inlay a)
    (:regions
      (ghost_init_region
          (:target industry_workbench)
          (:ranges (
              (-0.001 -0.001 0.001 0.001)
            )
          )
          (:yaw_rotation (
              (0 0)
            )
          )
      )
      (bottle_init_region
          (:target industry_workbench)
          (:ranges (
              (-0.23 -0.32999999999999996 -0.17 -0.27)
            )
          )
          (:yaw_rotation (
              (0 0)
            )
          )
      )
      (ghost_active_region
          (:target conveyor_ghost_1)
      )
    )

  (:fixtures
    industry_workbench - industry_workbench
    conveyor_ghost_1 - conveyor_ghost
  )

  (:objects
    pump_bottle_upright_1 - pump_bottle_upright
  )

  (:obj_of_interest
  )

  (:init
    (On conveyor_ghost_1 industry_workbench_ghost_init_region)
    (On pump_bottle_upright_1 industry_workbench_bottle_init_region)
    (LoadSlot conveyor_ghost_1 bottle_groove x steady 0.05)
  )

  (:goal
    (And (Routed pump_bottle_upright_1 conveyor_ghost_1))
  )

)
