(define (problem LIBERO_Kitchen_Tabletop_Manipulation)
  (:domain robosuite)
  (:language place box on conveyor belt)
    (:regions
      (conveyor_belt_init_region
          (:target kitchen_table)
          (:ranges (
              (-0.05 0.25 0.05 0.35)
            )
          )
          (:yaw_rotation (
              (0 3.141592653589793)
            )
          )
      )
      (box_region_1
          (:target kitchen_table)
          (:ranges (
              (-0.02 0.27999999999999997 0.02 0.32)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (box_region_2
          (:target kitchen_table)
          (:ranges (
              (-0.12000000000000001 0.27999999999999997 -0.08 0.32)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (belt_region
          (:target conveyor_belt_1)
      )
    )

  (:fixtures
    kitchen_table - kitchen_table
    conveyor_belt_1 - conveyor_belt
  )

  (:objects
    box_1 box_2 - box
  )

  (:obj_of_interest
  )

  (:init
    (On conveyor_belt_1 kitchen_table_conveyor_belt_init_region)
    (On box_1 kitchen_table_box_region_1)
    (On box_2 kitchen_table_box_region_2)
  )

  (:goal
    (And (On box_1 conveyor_belt_1_belt_region) (On box_2 conveyor_belt_1_belt_region))
  )

)
