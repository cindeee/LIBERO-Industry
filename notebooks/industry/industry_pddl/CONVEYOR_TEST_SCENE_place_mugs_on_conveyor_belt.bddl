(define (problem LIBERO_Kitchen_Tabletop_Manipulation)
  (:domain robosuite)
  (:language place mugs on conveyor belt)
    (:regions
      (conveyor_belt_init_region
          (:target kitchen_table)
          (:ranges (
              (0.09999999999999999 -0.05 0.2 0.05)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (box_region_1
          (:target kitchen_table)
          (:ranges (
              (-0.16999999999999998 0.06 -0.13 0.1)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (box_region_2
          (:target kitchen_table)
          (:ranges (
              (-0.16999999999999998 -0.1 -0.13 -0.06)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
    )

  (:fixtures
    kitchen_table - kitchen_table
  )

  (:objects
    conveyor_belt_1 - conveyor_belt
    box_1 box_2 - box
  )

  (:obj_of_interest
    box_1
    box_2
  )

  (:init
    (On conveyor_belt_1 kitchen_table_conveyor_belt_init_region)
    (On box_1 kitchen_table_box_region_1)
    (On box_2 kitchen_table_box_region_2)
  )

  (:goal
    (And (On box_1 conveyor_belt_1_belt) (On box_2 conveyor_belt_1_belt))
  )

)
